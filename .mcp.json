{
  "mcpServers": {
    "claude-flow": {
      "command": "npx",
      "args": [
        "-y",
        "@claude-flow/cli@latest",
        "mcp",
        "start"
      ],
      "env": {
        "npm_config_update_notifier": "false",
        "CLAUDE_FLOW_MODE": "v3",
        "CLAUDE_FLOW_HOOKS_ENABLED": "true",
        "CLAUDE_FLOW_TOPOLOGY": "hierarchical-mesh",
        "CLAUDE_FLOW_MAX_AGENTS": "15",
        "CLAUDE_FLOW_MEMORY_BACKEND": "hybrid"
      },
      "autoStart": false
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/user/jeffrymahbuubi/PROJECTS/1-fNIRS-Grid-Base-Method"
      ],
      "env": {}
    },
    "claude-skills-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "claude-skills-mcp",
        "--config",
        "/home/user/jeffrymahbuubi/PROJECTS/1-fNIRS-Grid-Base-Method/config/claude-skills-mcp.json"
      ],
      "env": {}
    },
    "jupyter-mcp-server": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "jupyter-mcp-server"
      ],
      "env": {
        "JUPYTER_URL": "http://localhost:8888",
        "JUPYTER_TOKEN": "my_secure_token_123",
        "DOCUMENT_ID": "",
        "ALLOW_IMG_OUTPUT": "true"
      }
    },
    "netmind-parse-pdf": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "netmind-parse-pdf-mcp"
      ],
      "env": {
        "NETMIND_API_TOKEN": "${NETMIND_API_TOKEN}"
      }
    }
  }
}