.vscode/settings.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Data (raw & processed datasets excluded; scripts/configs tracked) ──────
data/raw/
data/processed/

